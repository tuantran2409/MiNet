@model LoginVM;

<div class="sm:flex">
    @*form section*@
    <div class="relative lg:w-[580px] md:w-96 w-full p-10 min-h-screen bg-white shadow-xl flex items-center pt-10 z-10">

        <div class="w-full lg:max-w-sm mx-auto space-y-10">

            <div>
                <h2 class="text-2xl font-semibold mb-1.5">Sign in to your account</h2>
                <p class="text-sm text-gray-700 font-normal">If you have not signed up yet. <a asp-controller="Authentication" asp-action="Register" class="text-blue-700">Register here!</a></p>
            </div>

            @if (TempData["LoginError"] != null)
            {
                var errorType = TempData["LoginErrorType"]?.ToString();
                var attemptsLeft = TempData["AttemptsLeft"];
                var lockoutEnd = TempData["LockoutEnd"]?.ToString();

                @if (errorType == "admin-locked")
                {
                    <!-- Admin Locked Account -->
                    <div id="login-notification" class="flex items-start gap-3 p-4 rounded-lg bg-gray-100 border border-gray-300 text-gray-800 text-sm animate-shake" role="alert">
                        <ion-icon name="lock-closed" class="text-xl text-gray-600 flex-shrink-0 mt-0.5"></ion-icon>
                        <div class="flex-1">
                            <p class="font-semibold">Account Locked</p>
                            <p class="mt-0.5 text-gray-600">@TempData["LoginError"]</p>
                        </div>
                        <button type="button" onclick="document.getElementById('login-notification').style.display='none'" class="text-gray-400 hover:text-gray-600 transition-colors flex-shrink-0">
                            <ion-icon name="close" class="text-lg"></ion-icon>
                        </button>
                    </div>
                }
                else if (errorType == "auto-locked")
                {
                    <!-- Auto-Lockout with Countdown Timer -->
                    <div id="login-notification" class="flex items-start gap-3 p-4 rounded-lg bg-orange-50 border border-orange-200 text-orange-800 text-sm animate-shake" role="alert">
                        <ion-icon name="time" class="text-xl text-orange-500 flex-shrink-0 mt-0.5"></ion-icon>
                        <div class="flex-1">
                            <p class="font-semibold">Account Temporarily Locked</p>
                            <p class="mt-0.5 text-orange-600">@TempData["LoginError"]</p>
                            @if (lockoutEnd != null)
                            {
                                <p class="mt-2 font-semibold text-orange-700">
                                    <ion-icon name="hourglass-outline" class="align-middle"></ion-icon>
                                    Try again in: <span id="lockout-timer" class="font-mono" data-lockout-end="@Html.Raw(lockoutEnd)"></span>
                                </p>
                            }
                        </div>
                        <button type="button" onclick="document.getElementById('login-notification').style.display='none'" class="text-orange-400 hover:text-orange-600 transition-colors flex-shrink-0">
                            <ion-icon name="close" class="text-lg"></ion-icon>
                        </button>
                    </div>

                    @if (lockoutEnd != null)
                    {
                        <script>
                            (function () {
                                var timerEl = document.getElementById('lockout-timer');
                                var lockoutEnd = new Date(timerEl.getAttribute('data-lockout-end'));
                                var submitBtn = document.querySelector('button[type="submit"]');
                                if (submitBtn) { submitBtn.disabled = true; submitBtn.classList.add('opacity-50', 'cursor-not-allowed'); }

                                function updateTimer() {
                                    var now = new Date();
                                    var diff = lockoutEnd - now;
                                    if (diff <= 0) {
                                        timerEl.textContent = "0:00";
                                        if (submitBtn) { submitBtn.disabled = false; submitBtn.classList.remove('opacity-50', 'cursor-not-allowed'); }
                                        document.getElementById('login-notification').innerHTML =
                                            '<ion-icon name="checkmark-circle" class="text-xl text-green-500 flex-shrink-0 mt-0.5"></ion-icon>' +
                                            '<div class="flex-1"><p class="font-semibold text-green-800">Lockout Expired</p>' +
                                            '<p class="mt-0.5 text-green-600">You can try logging in again now.</p></div>';
                                        document.getElementById('login-notification').className = 'flex items-start gap-3 p-4 rounded-lg bg-green-50 border border-green-200 text-green-800 text-sm animate-shake';
                                        return;
                                    }
                                    var minutes = Math.floor(diff / 60000);
                                    var seconds = Math.floor((diff % 60000) / 1000);
                                    timerEl.textContent = minutes + ":" + (seconds < 10 ? "0" : "") + seconds;
                                    setTimeout(updateTimer, 1000);
                                }
                                updateTimer();
                            })();
                        </script>
                    }
                }
                else
                {
                    <!-- Wrong Credentials with Attempts Remaining -->
                    <div id="login-notification" class="flex items-start gap-3 p-4 rounded-lg bg-red-50 border border-red-200 text-red-800 text-sm animate-shake" role="alert">
                        <ion-icon name="alert-circle" class="text-xl text-red-500 flex-shrink-0 mt-0.5"></ion-icon>
                        <div class="flex-1">
                            <p class="font-semibold">Login Failed</p>
                            <p class="mt-0.5 text-red-600">@TempData["LoginError"]</p>
                            @if (attemptsLeft != null)
                            {
                                var attempts = (int)attemptsLeft;
                                <p class="mt-2 text-xs @(attempts <= 2 ? "text-red-700 font-bold" : "text-red-500")">
                                    <ion-icon name="warning-outline" class="align-middle"></ion-icon>
                                    @if (attempts <= 1)
                                    {
                                        <span>⚠️ Last attempt remaining! Your account will be locked after the next failed attempt.</span>
                                    }
                                    else
                                    {
                                        <span>You have <strong>@attempts</strong> attempt(s) remaining before your account is temporarily locked.</span>
                                    }
                                </p>
                            }
                        </div>
                        <button type="button" onclick="document.getElementById('login-notification').style.display='none'" class="text-red-400 hover:text-red-600 transition-colors flex-shrink-0">
                            <ion-icon name="close" class="text-lg"></ion-icon>
                        </button>
                    </div>
                }
            }

            <form asp-controller="Authentication" asp-action="Login" method="post" class="space-y-7 text-sm text-black font-medium">
                <div>
                    <label asp-for="Email">Email address</label>
                    <div class="mt-2.5">
                        <input asp-for="Email" id="email" name="email" type="email" placeholder="Email" required="" class="!w-full" />
                        <span asp-validation-for="Email" class="text-red-500 text-xs mt-1"></span>
                    </div>
                </div>
                <div>
                    <label asp-for="Password">Password</label>
                    <div class="mt-2.5">
                        <input asp-for="Password" id="password" name="password" type="password" placeholder="***" required="" class="!w-full" />
                        <span asp-validation-for="Password" class="text-red-500 text-xs mt-1"></span>
                    </div>
                </div>

                <div class="flex items-center justify-between">
                    <div class="flex items-center gap-2.5">
                        <input id="rememberme" name="rememberme" type="checkbox">
                        <label for="rememberme" class="font-normal">Remember me</label>
                    </div>
                    <a href="#" class="text-blue-700">Forget password</a>
                </div>

                <div>
                    <button type="submit" class="button bg-primary text-white w-full">Sign in</button>
                </div>

                <div class="text-center flex items-center gap-6">
                    <hr class="flex-1 border-slate-200">
                    Or continue with
                    <hr class="flex-1 border-slate-200">
                </div>

                <div class="flex gap-2">
                    <a asp-controller="Authentication" asp-action="ExternalLogin" asp-route-provider="Google" class="button flex-1 flex items-center gap-2 bg-primary text-white text-sm"> <ion-icon name="logo-google" class="text-lg"></ion-icon> google </a>
                    <a asp-controller="Authentication" asp-action="ExternalLogin" asp-route-provider="GitHub" class="button flex-1 flex items-center gap-2 bg-black text-white text-sm"><ion-icon name="logo-github" class="text-lg"></ion-icon> github </a>
                </div>
            </form>
        </div>
    </div>

    @*image slider*@
    <div class="flex-1 relative bg-primary max-md:hidden">
        <div class="relative w-full h-full" tabindex="-1" uk-slideshow="animation: slide; autoplay: true">

            <ul class="uk-slideshow-items w-full h-full">
                <li class="w-full">
                    <img src="~/images/welcome/welcome-01.png" alt="" class="w-full h-full object-cover uk-animation-kenburns uk-animation-reverse uk-transform-origin-center-left">

                        <div class="absolute bottom-0 w-full uk-transition-slide-bottom-small z-10">
                            <div class="max-w-xl w-full mx-auto pb-32 px-5 z-30 relative">
                                <h4 class="!text-white text-2xl font-semibold mt-7" uk-slideshow-parallax="y: 600,0,0">Connect with Friends</h4>
                                <p class="!text-white text-lg mt-7 leading-8" uk-slideshow-parallax="y: 800,0,0;">Bridge the gap between miles and moments—connect with friends and weave memories together, one click at a time.</p>
                            </div>
                        </div>
                        <div class="w-full h-96 bg-gradient-to-t from-black absolute bottom-0 left-0"></div>
                    </li>
                    <li class="w-full">
                        <img src="~/images/welcome/welcome-02.png" alt="" class="w-full h-full object-cover uk-animation-kenburns uk-animation-reverse uk-transform-origin-center-left">
                            <div class="absolute bottom-0 w-full uk-tr ansition-slide-bottom-small z-10">
                                <div class="max-w-xl w-full mx-auto pb-32 px-5 z-30 relative">
                                    <h4 class="!text-white text-2xl font-semibold mt-7" uk-slideshow-parallax="y: 800,0,0">  Connect With Friends </h4>
                                    <p class="!text-white text-lg mt-7 leading-8" uk-slideshow-parallax="y: 800,0,0;"> Rekindle old ties and spark new ones—your next 'Remember when...' moment is just a friend request away.</p>
                                </div>
                            </div>
                            <div class="w-full h-96 bg-gradient-to-t from-black absolute bottom-0 left-0"></div>
                        </li>
                    </ul>

                    <!-- slide nav -->
                    <div class="flex justify-center">
                        <ul class="inline-flex flex-wrap justify-center  absolute bottom-8 gap-1.5 uk-dotnav uk-slideshow-nav"> </ul>
                    </div>

                </div>
            </div>
        </div>