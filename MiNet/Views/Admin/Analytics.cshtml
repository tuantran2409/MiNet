@{
    ViewData["Title"] = "Analytics";
    var stats = ViewBag.stats;
    var topPosts = stats?.TopPosts as List<MiNet.Data.Models.Post>;
}

<main id="site__main" class="flex-1 overflow-y-auto">
    <div class="p-6 bg-gray-50 min-h-screen">

        <!-- Header -->
        <div class="mb-8">
            <h1 class="text-3xl font-bold text-gray-900">Analytics & Thống Kê</h1>
            <p class="text-gray-600 mt-2">Thống kê tổng quát về nền tảng MiNet</p>
        </div>

        <!-- Main Statistics -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">

            <div class="bg-white rounded-lg shadow p-6">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-gray-500 text-sm font-medium">👥 Tổng Người Dùng</p>
                        <p class="text-3xl font-bold text-blue-600 mt-2">@stats?.TotalUsers</p>
                    </div>
                    <div class="w-14 h-14 bg-blue-100 rounded-lg flex items-center justify-center">
                        <ion-icon class="text-2xl text-blue-600" name="people-outline"></ion-icon>
                    </div>
                </div>
            </div>

            <div class="bg-white rounded-lg shadow p-6">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-gray-500 text-sm font-medium">📝 Tổng Bài Viết</p>
                        <p class="text-3xl font-bold text-green-600 mt-2">@stats?.TotalPosts</p>
                    </div>
                    <div class="w-14 h-14 bg-green-100 rounded-lg flex items-center justify-center">
                        <ion-icon class="text-2xl text-green-600" name="document-text-outline"></ion-icon>
                    </div>
                </div>
            </div>

            <div class="bg-white rounded-lg shadow p-6">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-gray-500 text-sm font-medium">🚨 Tổng Báo Cáo</p>
                        <p class="text-3xl font-bold text-red-600 mt-2">@stats?.TotalReports</p>
                    </div>
                    <div class="w-14 h-14 bg-red-100 rounded-lg flex items-center justify-center">
                        <ion-icon class="text-2xl text-red-600" name="warning-outline"></ion-icon>
                    </div>
                </div>
            </div>

            <div class="bg-white rounded-lg shadow p-6">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-gray-500 text-sm font-medium">📊 Avg Posts/User</p>
                        <p class="text-3xl font-bold text-purple-600 mt-2">
                            @{
                                var avgPostsPerUser = stats?.TotalUsers > 0 ? (decimal)stats.TotalPosts / stats.TotalUsers : 0;
                            }
                            @avgPostsPerUser.ToString("F1")
                        </p>
                    </div>
                    <div class="w-14 h-14 bg-purple-100 rounded-lg flex items-center justify-center">
                        <ion-icon class="text-2xl text-purple-600" name="bar-chart-outline"></ion-icon>
                    </div>
                </div>
            </div>

        </div>

        <!-- Top Posts Section -->
        <div class="bg-white rounded-lg shadow overflow-hidden">
            <div class="p-6 border-b border-gray-200 flex items-center justify-between">
                <h2 class="text-xl font-semibold text-gray-900">🏆 Top 10 Bài Viết Phổ Biến</h2>
                <span class="bg-blue-100 text-blue-800 px-3 py-1 rounded-full text-sm font-medium">
                    @topPosts?.Count posts
                </span>
            </div>

            <div class="overflow-x-auto">
                <table class="w-full">
                    <thead class="bg-gray-50 border-b border-gray-200">
                        <tr>
                            <th class="px-6 py-3 text-left text-sm font-semibold text-gray-900">Rank</th>
                            <th class="px-6 py-3 text-left text-sm font-semibold text-gray-900">Người Tạo</th>
                            <th class="px-6 py-3 text-left text-sm font-semibold text-gray-900">Nội Dung</th>
                            <th class="px-6 py-3 text-center text-sm font-semibold text-gray-900">❤️ Thích</th>
                            <th class="px-6 py-3 text-center text-sm font-semibold text-gray-900">💬 Bình Luận</th>
                            <th class="px-6 py-3 text-center text-sm font-semibold text-gray-900">⭐ Yêu Thích</th>
                            <th class="px-6 py-3 text-left text-sm font-semibold text-gray-900">Ngày</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-200">
                        @if (topPosts != null)
                        {
                            @for (int i = 0; i < topPosts.Count; i++)
                            {
                                var post = topPosts[i];
                                var likesCount = post.Likes?.Count ?? 0;
                                var commentsCount = post.Comments?.Count ?? 0;
                                var favoritesCount = post.Favorites?.Count ?? 0;

                                <tr class="hover:bg-gray-50 transition">
                                    <td class="px-6 py-4">
                                        <div class="flex items-center justify-center">
                                            @if (i == 0)
                                            {
                                                <span class="text-2xl">🥇</span>
                                            }
                                            else if (i == 1)
                                            {
                                                <span class="text-2xl">🥈</span>
                                            }
                                            else if (i == 2)
                                            {
                                                <span class="text-2xl">🥉</span>
                                            }
                                            else
                                            {
                                                <span class="text-lg font-bold text-gray-600">#@(i + 1)</span>
                                            }
                                        </div>
                                    </td>
                                    <td class="px-6 py-4">
                                        <div class="flex items-center">
                                            <img src="@(!string.IsNullOrEmpty(post.User.ProfilePictureUrl) ?
                                                                                                       Url.Content("~/" + post.User.ProfilePictureUrl) :
                                                                                                       Url.Content("~/images/avatar/user.png"))"
                                         class="w-8 h-8 rounded-full mr-3" />
                                    <span class="text-sm font-medium text-gray-900">@post.User.Name</span>
                                </div>
                            </td>
                            <td class="px-6 py-4">
                                <p class="text-sm text-gray-700 max-w-xs truncate">@post.Content</p>
                            </td>
                            <td class="px-6 py-4 text-center">
                                <span class="bg-red-100 text-red-800 px-3 py-1 rounded-full text-sm font-medium">
                                    @likesCount
                                </span>
                            </td>
                            <td class="px-6 py-4 text-center">
                                <span class="bg-blue-100 text-blue-800 px-3 py-1 rounded-full text-sm font-medium">
                                    @commentsCount
                                </span>
                            </td>
                            <td class="px-6 py-4 text-center">
                                <span class="bg-yellow-100 text-yellow-800 px-3 py-1 rounded-full text-sm font-medium">
                                    @favoritesCount
                                </span>
                            </td>
                            <td class="px-6 py-4 text-sm text-gray-600">
                                @post.DateCreated.ToString("dd/MM/yyyy")
                            </td>
                        </tr>
                                                }
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Charts Section (Placeholder) -->
        <div class="mt-8 grid grid-cols-2 gap-6">

            <div class="bg-white rounded-lg shadow p-6">
                <h3 class="text-lg font-semibold text-gray-900 mb-4">📈 Xu Hướng Người Dùng</h3>
                <div class="h-64 bg-gray-100 rounded-lg flex items-center justify-center">
                    <p class="text-gray-500">Chart sẽ được thêm với Chart.js hoặc ApexCharts</p>
                </div>
            </div>

            <div class="bg-white rounded-lg shadow p-6">
                <h3 class="text-lg font-semibold text-gray-900 mb-4">📊 Phân Phối Hoạt Động</h3>
                <div class="h-64 bg-gray-100 rounded-lg flex items-center justify-center">
                    <p class="text-gray-500">Chart sẽ được thêm với Chart.js hoặc ApexCharts</p>
                </div>
            </div>

        </div>

    </div>
</main>