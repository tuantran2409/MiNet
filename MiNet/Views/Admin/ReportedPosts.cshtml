@model List<Post>

@{
    ViewData["Title"] = "Bài Viết Bị Báo Cáo";
}

<main id="site__main" class="flex-1 overflow-y-auto">
    <div class="p-6 bg-gray-50 min-h-screen">

        <!-- Success Message -->
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="mb-6 p-4 bg-green-100 border border-green-400 text-green-800 rounded-lg flex items-center">
                <ion-icon name="checkmark-circle-outline" class="text-2xl mr-3"></ion-icon>
                <span class="font-medium">@TempData["SuccessMessage"]</span>
                <button onclick="this.parentElement.style.display='none'" class="ml-auto text-green-600 hover:text-green-800">
                    <ion-icon name="close-outline"></ion-icon>
                </button>
            </div>
        }

        <div class="mb-8">
            <h1 class="text-3xl font-bold text-gray-900">Bài Viết Bị Báo Cáo</h1>
            <p class="text-gray-600 mt-2">@Model.Count bài viết đang chờ xử lý</p>
        </div>

        @if (Model.Count == 0)
        {
            <div class="bg-white rounded-lg shadow p-12 text-center">
                <ion-icon class="text-6xl text-green-400" name="checkmark-circle-outline"></ion-icon>
                <p class="text-gray-600 text-lg mt-4">Không có bài viết nào bị báo cáo</p>
            </div>
        }
        else
        {
            <div class="grid grid-cols-1 gap-6">
                @foreach (var post in Model)
                {
                    <div class="bg-white rounded-lg shadow overflow-hidden hover:shadow-lg transition">

                        <div class="p-6 border-b border-gray-200">
                            <div class="flex items-start justify-between">
                                <div class="flex items-center flex-1">
                                    <img src="@(!string.IsNullOrEmpty(post.User.ProfilePictureUrl) ?
                                                                                       Url.Content("~/" + post.User.ProfilePictureUrl) :
                                                                                       Url.Content("~/images/avatar/user.png"))"
                                 class="w-14 h-14 rounded-full mr-4" />
                            <div>
                                <a href="@Url.Action("UserDetails", new { userId = post.User.Id })"
                                   class="font-semibold text-gray-900 hover:text-blue-600">
                                    @post.User.Name
                                </a>
                                <p class="text-sm text-gray-500">@post.DateCreated.ToString("dd/MM/yyyy HH:mm:ss")</p>
                                <p class="text-xs text-gray-400">ID Bài: @post.Id</p>
                            </div>
                        </div>
                        <div class="text-right">
                            <div class="inline-block bg-red-100 px-4 py-2 rounded-lg">
                                <p class="text-red-800 font-bold text-lg">⚠️ @post.NrOfReports</p>
                                <p class="text-red-600 text-xs font-medium">báo cáo</p>
                            </div>
                        </div>
                    </div>
                </div>

                        <div class="p-6 border-b border-gray-200 bg-gray-50">
                            <h3 class="font-semibold text-gray-900 mb-3">📝 Nội Dung Bài Viết:</h3>
                            <div class="bg-white p-4 rounded-lg border border-gray-200">
                                <p class="text-gray-800 leading-relaxed">@post.Content</p>
                            </div>

                    @if (!string.IsNullOrEmpty(post.ImageUrl))
                            {
                                <div class="mt-4">
                                    <img src="@Url.Content("~/" + post.ImageUrl)" class="w-full max-h-96 object-cover rounded-lg shadow" />
                                </div>
                            }

                            <!-- Post Stats -->
                            <div class="mt-4 grid grid-cols-3 gap-4">
                                <div class="bg-red-50 p-3 rounded-lg text-center">
                                    <p class="text-gray-600 text-sm">Lượt Thích</p>
                                    <p class="text-2xl font-bold text-red-600">@(post.Likes?.Count ?? 0)</p>
                                </div>
                                <div class="bg-blue-50 p-3 rounded-lg text-center">
                                    <p class="text-gray-600 text-sm">Bình Luận</p>
                                    <p class="text-2xl font-bold text-blue-600">@(post.Comments?.Count ?? 0)</p>
                                </div>
                                <div class="bg-yellow-50 p-3 rounded-lg text-center">
                                    <p class="text-gray-600 text-sm">Yêu Thích</p>
                                    <p class="text-2xl font-bold text-yellow-600">@(post.Favorites?.Count ?? 0)</p>
                                </div>
                            </div>
                        </div>

                        <!-- Action Buttons -->
                        <div class="p-6 bg-white flex gap-3">
                            <!-- ✅ XEM CHI TIẾT -->
                            <a href="@Url.Action("PostDetails", new { postId = post.Id })"
                               class="flex-1 bg-blue-600 text-white px-4 py-3 rounded-lg hover:bg-blue-700 font-semibold transition text-center">
                                <ion-icon name="eye-outline" class="mr-2"></ion-icon>Xem Chi Tiết
                            </a>

                            <!-- ✅ XÓA BÀI VIẾT -->
                            <form asp-controller="Admin" asp-action="ApproveReport" method="post" class="flex-1">
                                <input type="hidden" name="postId" value="@post.Id" />
                                <button type="submit" onclick="return confirm('Bạn chắc chắn muốn XÓA bài viết này? Hành động không thể hoàn tác!');"
                                        class="w-full bg-red-600 text-white px-4 py-3 rounded-lg hover:bg-red-700 font-semibold transition">
                                    <ion-icon name="trash-outline" class="mr-2"></ion-icon>Xóa Bài
                                </button>
                            </form>

                            <!-- ✅ TỪCHỐI BÁO CÁO -->
                            <form asp-controller="Admin" asp-action="RejectReport" method="post" class="flex-1">
                                <input type="hidden" name="postId" value="@post.Id" />
                                <button type="submit" class="w-full bg-green-600 text-white px-4 py-3 rounded-lg hover:bg-green-700 font-semibold transition">
                                    <ion-icon name="close-circle-outline" class="mr-2"></ion-icon>Từ Chối
                                </button>
                            </form>
                        </div>

                    </div>
                }
            </div>
        }

    </div>
</main>