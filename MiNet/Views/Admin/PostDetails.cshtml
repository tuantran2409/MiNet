@model Post

@{
    ViewData["Title"] = "Chi Tiết Bài Viết";
    var reports = ViewBag.Reports as List<MiNet.Data.Models.Report>;
}

<main id="site__main" class="flex-1 overflow-y-auto">
    <div class="p-6 bg-gray-50 min-h-screen">

        <!-- Success Message -->
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="mb-6 p-4 bg-green-100 border border-green-400 text-green-800 rounded-lg flex items-center">
                <ion-icon name="checkmark-circle-outline" class="text-2xl mr-3"></ion-icon>
                <span class="font-medium">@TempData["SuccessMessage"]</span>
            </div>
        }

        <!-- Header -->
        <div class="mb-8">
            <a href="@Url.Action("ReportedPosts")" class="text-blue-600 hover:text-blue-800 font-medium mb-4 inline-block">
                ← Quay Lại Danh Sách
            </a>
            <h1 class="text-3xl font-bold text-gray-900">Chi Tiết Bài Viết Bị Báo Cáo</h1>
        </div>

        <div class="grid grid-cols-3 gap-6">

            <!-- Post Content - Left (2 columns) -->
            <div class="col-span-2">

                <div class="bg-white rounded-lg shadow overflow-hidden mb-6">

                    <!-- Post Header -->
                    <div class="p-6 border-b border-gray-200">
                        <div class="flex items-start justify-between">
                            <div class="flex items-center flex-1">
                                <img src="@(!string.IsNullOrEmpty(Model.User.ProfilePictureUrl) ?
                                                                               Url.Content("~/" + Model.User.ProfilePictureUrl) :
                                                                               Url.Content("~/images/avatar/user.png"))"
                                     class="w-14 h-14 rounded-full mr-4" />
                                <div>
                                    <a href="@Url.Action("UserDetails", new { userId = Model.User.Id })"
                                       class="font-semibold text-gray-900 hover:text-blue-600">
                                        @Model.User.Name
                                    </a>
                                    <p class="text-sm text-gray-500">@Model.DateCreated.ToString("dd/MM/yyyy HH:mm:ss")</p>
                                </div>
                            </div>
                            <div class="bg-red-100 px-4 py-2 rounded-lg">
                                <p class="text-red-800 font-bold text-lg">⚠️ @Model.NrOfReports</p>
                                <p class="text-red-600 text-xs">báo cáo</p>
                            </div>
                        </div>
                    </div>

                    <!-- Post Content -->
                    <div class="p-6 border-b border-gray-200 bg-gray-50">
                        <p class="text-gray-800 text-lg leading-relaxed">@Model.Content</p>

                        @if (!string.IsNullOrEmpty(Model.ImageUrl))
                        {
                            <div class="mt-6">
                                <img src="@Url.Content("~/" + Model.ImageUrl)" class="w-full rounded-lg shadow" />
                            </div>
                        }
                    </div>

                    <!-- Stats -->
                    <div class="p-6 grid grid-cols-3 gap-4">
                        <div class="bg-red-50 p-4 rounded-lg text-center">
                            <p class="text-gray-600 text-sm font-medium">Lượt Thích</p>
                            <p class="text-3xl font-bold text-red-600 mt-2">@(Model.Likes?.Count ?? 0)</p>
                        </div>
                        <div class="bg-blue-50 p-4 rounded-lg text-center">
                            <p class="text-gray-600 text-sm font-medium">Bình Luận</p>
                            <p class="text-3xl font-bold text-blue-600 mt-2">@(Model.Comments?.Count ?? 0)</p>
                        </div>
                        <div class="bg-yellow-50 p-4 rounded-lg text-center">
                            <p class="text-gray-600 text-sm font-medium">Yêu Thích</p>
                            <p class="text-3xl font-bold text-yellow-600 mt-2">@(Model.Favorites?.Count ?? 0)</p>
                        </div>
                    </div>

                    <!-- Action Buttons -->
                    <div class="p-6 bg-white border-t border-gray-200 flex gap-3">
                        @if (Model.IsDeleted)
                        {
                            <div class="flex-1 bg-red-50 border border-red-200 rounded-lg p-4 text-center">
                                <p class="text-red-800 font-semibold">
                                    <ion-icon name="checkmark-outline"></ion-icon> Đã Xóa
                                </p>
                            </div>
                        }
                        else
                        {
                            <form asp-controller="Admin" asp-action="ApproveReport" method="post" class="flex-1">
                                <input type="hidden" name="postId" value="@Model.Id" />
                                <button type="submit"
                                        onclick="return confirm('Xóa bài viết này? Không thể hoàn tác!');"
                                        class="w-full bg-red-600 text-white px-4 py-3 rounded-lg hover:bg-red-700 font-semibold transition">
                                    <ion-icon name="trash-outline" class="mr-2"></ion-icon>Xóa Bài Viết
                                </button>
                            </form>

                            <form asp-controller="Admin" asp-action="RejectReport" method="post" class="flex-1">
                                <input type="hidden" name="postId" value="@Model.Id" />
                                <button type="submit" class="w-full bg-green-600 text-white px-4 py-3 rounded-lg hover:bg-green-700 font-semibold transition">
                                    <ion-icon name="close-circle-outline" class="mr-2"></ion-icon>Từ Chối Báo Cáo
                                </button>
                            </form>
                        }
                    </div>

                </div>

            </div>

            <!-- Reports List - Right (1 column) -->
            <div>
                <div class="bg-white rounded-lg shadow overflow-hidden sticky top-6">
                    <div class="p-4 bg-red-50 border-b border-gray-200">
                        <h3 class="font-semibold text-gray-900 text-lg">
                            🚩 Danh Sách Báo Cáo (@(reports?.Count ?? 0))
                        </h3>
                    </div>

                    <div class="max-h-96 overflow-y-auto">
                        @if (reports == null || reports.Count == 0)
                        {
                            <div class="p-6 text-center text-gray-500">
                                Không có báo cáo nào
                            </div>
                        }
                        else
                        {
                            @foreach (var report in reports)
                            {
                                <div class="p-4 border-b border-gray-100 hover:bg-gray-50 transition">
                                    <div class="flex items-start">
                                        <img src="@(!string.IsNullOrEmpty(report.User.ProfilePictureUrl) ?
                                                                                               Url.Content("~/" + report.User.ProfilePictureUrl) :
                                                                                               Url.Content("~/images/avatar/user.png"))"
                                     class="w-8 h-8 rounded-full mr-3 flex-shrink-0" />
                                <div class="flex-1 min-w-0">
                                    <a href="@Url.Action("UserDetails", new { userId = report.User.Id })"
                                       class="text-sm font-medium text-gray-900 hover:text-blue-600">
                                        @report.User.Name
                                    </a>
                                    <p class="text-xs text-gray-500">@report.DateCreated.ToString("dd/MM HH:mm")</p>
                                    <p class="text-xs text-gray-400 mt-1">ID: @report.UserId</p>
                                </div>
                            </div>
                        </div>
                                                }
                        }
                    </div>
                </div>

                <!-- Quick Info -->
                <div class="bg-white rounded-lg shadow p-4 mt-6">
                    <h4 class="font-semibold text-gray-900 mb-4">ℹ️ Thông Tin</h4>
                    <div class="space-y-3 text-sm">
                        <div>
                            <p class="text-xs text-gray-500 uppercase font-medium">Mã Bài</p>
                            <p class="font-mono bg-gray-100 p-2 rounded">@Model.Id</p>
                        </div>
                        <div>
                            <p class="text-xs text-gray-500 uppercase font-medium">Tác Giả</p>
                            <p>@Model.User.Name</p>
                        </div>
                        <div>
                            <p class="text-xs text-gray-500 uppercase font-medium">Ngày Tạo</p>
                            <p>@Model.DateCreated.ToString("dd/MM/yyyy HH:mm")</p>
                        </div>
                    </div>
                </div>

            </div>

        </div>

    </div>
</main>