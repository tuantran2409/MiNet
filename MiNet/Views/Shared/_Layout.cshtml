<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MiNet</title>
    <link href="~/images/favicon.png" rel="icon" type="image"/>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/style.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/tailwind.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/MiNet.styles.css" asp-append-version="true" />
</head>
<body>

    <div id="wrapper">

        @if (User.Identity.IsAuthenticated)
        {
            @if (User.IsInRole(AppRoles.User))
            {
                <partial name="Navigation/_TopBar" />
                <partial name="Navigation/_SideBar" />
            }
            else if (User.IsInRole(AppRoles.Admin))
            {
                <partial name="Navigation/_TopBarAdmin" />
            }
        }
        <!-- Admin Menu Item (chỉ hiển thị với admin) -->
        @if (User.IsInRole("admin"))
        {
            <a href="@Url.Action("Index", "Admin")" class="nav-link">
                <ion-icon name="settings-outline"></ion-icon>
                Admin
            </a>
        }
        @RenderBody()
    </div>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @* //asset script *@
    <script src="~/js/uikit.min.js"></script>
    <script src="~/js/simplebar.js"></script>
    <script src="~/js/script.js"></script>

    @* Ion Icon *@
    <script type="module" src="https://unpkg.com/ionicons@5.5.2/dist/ionicons/ionicons.esm.js"></script>
    <script nomodule src="https://unpkg.com/ionicons@5.5.2/dist/ionicons/ionicons.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
